{
  "name": "fonte",
  "version": "0.0.20",
  "description": "A torrent client run by agents.",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "fonte": "packages/cli/bin/fonte.mjs"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "build": "tsc --build",
    "test": "vitest run",
    "sync:types": "node scripts/sync-api-types.mjs",
    "dev": "concurrently -k -n core,server,main \"npm run dev -w @fonte/core\" \"npm run dev -w @fonte/server\" \"npm run dev -w @fonte/main\"",
    "build:core": "npm run build -w @fonte/core",
    "build:server": "npm run build -w @fonte/server",
    "start": "npm run start -w @fonte/main",
    "server": "npm run start -w @fonte/server"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.9",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.7"
  }
}
